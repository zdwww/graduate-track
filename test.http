### Register a new user
# @name register
POST http://localhost:3000/api/auth/register
content-type: application/json

{
    "name": "John Doe",
    "email": "example@example.com",
    "password": "test_test"
}

### Login (captures the token used by the requests below)
# @name login
POST http://localhost:3000/api/auth/login
content-type: application/json

{
    "email": "example@example.com",
    "password": "test_test"
}

### Current user
GET http://localhost:3000/api/auth/me
Authorization: Bearer {{login.response.body.token}}

### List schools (catalog)
GET http://localhost:3000/api/schools
Authorization: Bearer {{login.response.body.token}}

### School / program by id
GET http://localhost:3000/api/schools/carnegie-mellon-m-s-in-computer-science-ms
Authorization: Bearer {{login.response.body.token}}

### Faculty for a program
GET http://localhost:3000/api/faculty?programId=carnegie-mellon-m-s-in-computer-science-ms
Authorization: Bearer {{login.response.body.token}}

### Create an application
POST http://localhost:3000/api/applications
content-type: application/json
Authorization: Bearer {{login.response.body.token}}

{
    "schoolName": "Carnegie Mellon University",
    "programId": "carnegie-mellon-m-s-in-computer-science-ms",
    "programName": "M.S. in Computer Science",
    "deadlines": []
}

### List my applications
GET http://localhost:3000/api/applications
Authorization: Bearer {{login.response.body.token}}

### Update an application (paste an _id from the list above)
PATCH http://localhost:3000/api/application/PASTE_APPLICATION_ID
content-type: application/json
Authorization: Bearer {{login.response.body.token}}

{
    "status": "Applied"
}

### Delete an application
DELETE http://localhost:3000/api/application/PASTE_APPLICATION_ID
Authorization: Bearer {{login.response.body.token}}

### Create a contact (paste one of your application ids)
# @name createContact
POST http://localhost:3000/api/contacts
content-type: application/json
Authorization: Bearer {{login.response.body.token}}

{
    "applicationId": "PASTE_APPLICATION_ID",
    "name": "Dr. Jane Smith",
    "school": "Carnegie Mellon University",
    "role": "Professor",
    "email": "jsmith@cmu.edu",
    "notes": "Met at the fall open house"
}

### List all my contacts
GET http://localhost:3000/api/contacts
Authorization: Bearer {{login.response.body.token}}

### List contacts for one application
GET http://localhost:3000/api/contacts?applicationId=PASTE_APPLICATION_ID
Authorization: Bearer {{login.response.body.token}}

### Get a contact by id
GET http://localhost:3000/api/contact/{{createContact.response.body.contact._id}}
Authorization: Bearer {{login.response.body.token}}

### Update a contact
PATCH http://localhost:3000/api/contact/{{createContact.response.body.contact._id}}
content-type: application/json
Authorization: Bearer {{login.response.body.token}}

{
    "role": "Associate Professor",
    "notes": "Followed up by email"
}

### Delete a contact
DELETE http://localhost:3000/api/contact/{{createContact.response.body.contact._id}}
Authorization: Bearer {{login.response.body.token}}
